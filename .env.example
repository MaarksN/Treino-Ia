# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase social/community backend.
VITE_ENV="development"
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_ANON_KEY="SUA_ANON_KEY"

# Supabase server-side APIs. Never expose the service role key to the browser.
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="SUA_SERVICE_ROLE_KEY"

# Supabase CLI migrations. Keep these outside the frontend bundle.
# Use either SUPABASE_ACCESS_TOKEN with a linked project, or SUPABASE_DB_URL for direct db push/list commands.
SUPABASE_ACCESS_TOKEN=""
SUPABASE_DB_URL=""

# Billing / Stripe server-side APIs.
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRICE_PRO_MONTHLY="price_xxx"
STRIPE_PRICE_PRO_YEARLY="price_xxx"
STRIPE_PRICE_COACH_MONTHLY="price_xxx"
STRIPE_PRICE_COACH_YEARLY="price_xxx"
STRIPE_PRICE_ELITE_MONTHLY="price_xxx"
STRIPE_PRICE_ELITE_YEARLY="price_xxx"

# Observability / analytics
VITE_SENTRY_DSN=""
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://app.posthog.com"

# Optional: route frontend AI calls through an API proxy instead of exposing a key.
VITE_GEMINI_PROXY_URL="/api/gemini-proxy"

# Retention worker / notifications. RETENTION_WORKER_SECRET can mirror Vercel CRON_SECRET.
RETENTION_WORKER_SECRET="change_me"
CRON_SECRET="change_me"
RETENTION_NOTIFICATION_WEBHOOK_URL=""
RETENTION_NOTIFICATION_WEBHOOK_SECRET=""

# Health OAuth connectors. Secrets are server-side only.
GOOGLE_FIT_CLIENT_ID=""
GOOGLE_FIT_CLIENT_SECRET=""
FITBIT_CLIENT_ID=""
FITBIT_CLIENT_SECRET=""
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# CI/CD secrets configured in GitHub, not committed in .env files.
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""
SENTRY_AUTH_TOKEN=""
LHCI_GITHUB_APP_TOKEN=""
